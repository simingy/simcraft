# --- Stage 1: Build the Frontend (static export) ---
FROM node:20-alpine AS frontend-builder
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi
COPY frontend/ .
# DESKTOP_BUILD=1 triggers output:"export" in next.config.mjs and unoptimized images
# NEXT_PUBLIC_API_URL="" makes all API calls relative (e.g. /api/sim), so the
# Rust backend serves both the UI and the API on the same port.
ENV DESKTOP_BUILD=1
ENV NEXT_PUBLIC_API_URL=""
RUN npm run build

# --- Stage 2: Build the Rust Backend ---
FROM rust:1.88-alpine AS backend-builder
RUN apk add --no-cache musl-dev
WORKDIR /build
COPY backend/Cargo.toml ./
COPY backend/core/ core/
COPY backend/server/ server/
RUN cargo build --release -p simhammer-server

# --- Stage 3: Final Runtime ---
# Node.js is needed to run compact-data.js at startup.
FROM node:20-alpine

RUN apk add --no-cache \
    ca-certificates curl jq bash libcurl libstdc++ gcompat \
    && rm -rf /var/cache/apk/*

WORKDIR /app

# Bake in the static frontend
COPY --from=frontend-builder /app/out /app/frontend

# Bake in the Rust server binary
COPY --from=backend-builder /build/target/release/simhammer-server /usr/local/bin/simhammer-server

# Bake in the data compaction script and the default season config
COPY backend/scripts/compact-data.js /app/compact-data.js
COPY backend/core/season-config.json /app/default_season_config.json

# Bake in the entrypoint
COPY standalone-entrypoint.sh /app/standalone-entrypoint.sh
RUN chmod +x /app/standalone-entrypoint.sh

# Volumes for persistent caching of fetched game data, the simc binary, and the SQLite db
VOLUME ["/app/resources/data", "/app/resources/data_full", "/app/resources/simc", "/app/db"]

ENV DATA_DIR=/app/resources/data
ENV SIMC_PATH=/usr/local/bin/simc
ENV FRONTEND_DIR=/app/frontend
ENV DATABASE_URL=/app/db/simhammer.db
ENV BIND_HOST=0.0.0.0
ENV PORT=8000

EXPOSE 8000
ENTRYPOINT ["/app/standalone-entrypoint.sh"]
CMD ["simhammer-server"]
